generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String        @unique
  password     String
  cvPath       String?
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  applications Application[]

  @@map("users")
}

model Company {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cityId Int?
  city   City? @relation(fields: [cityId], references: [id])

  jobs Job[]

  @@map("companies")
}

model City {
  id         Int      @id @default(autoincrement())
  name       String
  postalCode String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  companies Company[]
  jobs      Job[]

  @@map("cities")
}

model Job {
  id            Int      @id @default(autoincrement())
  title         String
  description   String   @db.Text
  remoteAllowed Boolean  @default(false)
  salaryMin     Int?
  salaryMax     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  cityId Int?
  city   City? @relation(fields: [cityId], references: [id])

  applications Application[]
  categories   JobCategoryOnJob[]
  types        JobTypeOnJob[]

  @@map("jobs")
}

model JobCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs JobCategoryOnJob[]

  @@map("job_categories")
}

model JobType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs JobTypeOnJob[]

  @@map("job_types")
}

model Application {
  id          Int               @id @default(autoincrement())
  coverLetter String            @db.Text
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  jobId Int
  job   Job @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
  @@map("applications")
}

model ContactRequest {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String
  subject     String
  message     String   @db.Text
  dataConsent Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("contact_requests")
}

model JobCategoryOnJob {
  jobId      Int
  categoryId Int

  job      Job         @relation(fields: [jobId], references: [id])
  category JobCategory @relation(fields: [categoryId], references: [id])

  @@id([jobId, categoryId])
  @@map("job_category_on_job")
}

model JobTypeOnJob {
  jobId  Int
  typeId Int

  job  Job     @relation(fields: [jobId], references: [id])
  type JobType @relation(fields: [typeId], references: [id])

  @@id([jobId, typeId])
  @@map("job_type_on_job")
}

enum Role {
  USER
  ADMIN
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}