generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  email          String   @unique
  password       String
  cvPath         String?
  cvOriginalName String?
  role           Role     @default(USER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  applications Application[]

  @@map("users")
}

model Company {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  address     String

  cityId Int
  city   City @relation(fields: [cityId], references: [id])

  jobs Job[]

  @@map("companies")
}

model City {
  id         Int    @id @default(autoincrement())
  name       String
  postalCode String

  companies Company[]
  jobs      Job[]

  @@map("cities")
}

model Job {
  id            Int      @id @default(autoincrement())
  title         String
  description   String
  remoteAllowed Boolean  @default(false)
  salaryMin     Int?
  salaryMax     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyId Int
  cityId    Int

  company Company @relation(fields: [companyId], references: [id])
  city    City    @relation(fields: [cityId], references: [id])

  applications Application[]
  categories   JobCategoryOnJob[]
  types        JobTypeOnJob[]

  views      JobView?
  dailyViews JobDailyView[]

  @@map("jobs")
}

model Application {
  id          Int               @id @default(autoincrement())
  coverLetter String
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userId Int
  jobId  Int

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
  @@map("applications")
}

model JobCategory {
  id   Int    @id @default(autoincrement())
  name String @unique

  jobs JobCategoryOnJob[]

  @@map("job_categories")
}

model JobType {
  id   Int    @id @default(autoincrement())
  name String @unique

  jobs JobTypeOnJob[]

  @@map("job_types")
}

model JobCategoryOnJob {
  jobId      Int
  categoryId Int

  job      Job         @relation(fields: [jobId], references: [id])
  category JobCategory @relation(fields: [categoryId], references: [id])

  @@id([jobId, categoryId])
  @@map("job_category_on_job")
}

model JobTypeOnJob {
  jobId  Int
  typeId Int

  job  Job     @relation(fields: [jobId], references: [id])
  type JobType @relation(fields: [typeId], references: [id])

  @@id([jobId, typeId])
  @@map("job_type_on_job")
}

model ContactRequest {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String
  subject     String
  message     String
  dataConsent Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("contact_requests")
}

model JobView {
  id        Int      @id @default(autoincrement())
  total     Int      @default(0)
  updatedAt DateTime @updatedAt

  jobId Int @unique
  job   Job @relation(fields: [jobId], references: [id])

  @@map("job_views")
}

model JobDailyView {
  id    Int      @id @default(autoincrement())
  day   DateTime
  views Int      @default(0)

  jobId Int
  job   Job @relation(fields: [jobId], references: [id])

  @@unique([jobId, day])
  @@map("job_daily_views")
}

enum Role {
  USER
  ADMIN
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}